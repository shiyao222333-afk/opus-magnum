# OpusMagnum · 巨作 — 环境变量模板
# 复制此文件为 .env 并填写实际值

# ---- GitHub 认证 ----
# 个人访问令牌（只需要 read 权限即可读取 Issues 和仓库信息）
# 创建路径: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=shiyao222333-afk

# ---- 仓库名称（默认已填，可按需修改）----
ATHANOR_REPO=shiyao222333-afk/citrinitas
ALEMBIC_REPO=shiyao222333-afk/nigredo
CRUCIBLE_REPO=shiyao222333-afk/albedo
ALUDEL_REPO=shiyao222333-afk/rubedo
OPUSMAGNUM_REPO=shiyao222333-afk/opus-magnum

# ---- 子项目地址（默认已填，可按需修改）----
# Athanor 已迁移到 NiceGUI，默认端口 8080
ATHANOR_URL=http://localhost:8080
ATHANOR_PORT=8080

ALEMBIC_URL=http://localhost:8502
ALEMBIC_PORT=8502

CRUCIBLE_URL=http://localhost:8501
CRUCIBLE_PORT=8501

ALUDEL_URL=http://localhost:8765
ALUDEL_PORT=8765

# ---- OpusMagnum 自身 ----
OPUSMAGNUM_URL=http://localhost:8500
OPUSMAGNUM_PORT=8500

# ---- API 认证 ----
# 各子项目间通信的 API Key
OPUS_API_KEY=opus-magnum-local

# ---- 日志 ----
LOG_LEVEL=INFO
